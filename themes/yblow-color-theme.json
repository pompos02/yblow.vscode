    "editor.background": "#112e2a",

    // Syntax Colors
    "editorCursor.foreground": "#d8c5a7",
    "editor.lineHighlightBackground": "#163732",
    "editorLineNumber.foreground": "#52756e",
    "editorLineNumber.activeForeground": "#d8c5a7",
    "editorWhitespace.foreground": "#52756e",
    "editorIndentGuide.background1": "#52756e",
    "editor.selectionBackground": "#8eaca533",
    "editor.inactiveSelectionBackground": "#8eaca522",
    "editor.selectionHighlightBackground": "#163732",
    "editor.wordHighlightBackground": "#748a921a",
    "editor.wordHighlightStrongBackground": "#748a921a",
    "editor.wordHighlightBorder": "#748a92",
    "editor.wordHighlightStrongBorder": "#748a92",
    "editor.findMatchBackground": "#26524b",
    "editor.findMatchHighlightBackground": "#26524b",
    "editor.findRangeHighlightBackground": "#26524b",
    "editor.hoverHighlightBackground": "#26524b",
    "editorOverviewRuler.findMatchForeground": "#26524b",
    "editorOverviewRuler.selectionHighlightForeground": "#26524b",

    // Syntax Highlighting
    "editorError.foreground": "#F43841",
    "editorWarning.foreground": "#cc8c3c",
    "editorInfo.foreground": "#2ea87e",
    "editorHint.foreground": "#7ad0c6",
    "editorGutter.modifiedBackground": "#2ea87e",
    "editorGutter.addedBackground": "#2ea87e",
    "editorGutter.deletedBackground": "#F43841",

    // UI Elements
    "focusBorder": "#748a92",
    "descriptionForeground": "#e7e2d8",
    "activityBar.background": "#112e2a",
    "activityBar.border": "#1b413b",
    "activityBar.foreground": "#f3efe6",
    "sideBar.foreground": "#f3efe6",
    "sideBarTitle.foreground": "#f3efe6",
    "sideBarSectionHeader.foreground": "#f3efe6",
    "activityBarBadge.background": "#2ea87e",
    "activityBarBadge.foreground": "#112e2a",
    "sideBar.background": "#112e2a",
    "sideBar.border": "#1b413b",
    "sideBarSectionHeader.background": "#112e2a",
    "sideBarSectionHeader.border": "#1b413b",
    "titleBar.activeBackground": "#112e2a",
    "titleBar.border": "#1b413b",
    "titleBar.inactiveBackground": "#112e2a",
    "chat.requestBackground": "#112e2a",
    "statusBar.background": "#112e2a",
    "titleBar.activeForeground": "#f3efe6",
    "titleBar.inactiveForeground": "#e7e2d8",
    "statusBar.foreground": "#f3efe6",
    "statusBarItem.prominentBackground": "#163732",
    "statusBarItem.prominentHoverBackground": "#26524b",
    "editorGroupHeader.tabsBackground": "#112e2a",
    "editorGroup.border": "#1b413b",
    "tab.activeBackground": "#112e2a",
    "tab.inactiveBackground": "#163732",
    "tab.border": "#1b413b",
    "tab.activeBorder": "#00000000",
    "tab.activeBorderTop": "#d8c5a7",
    "tab.activeForeground": "#f3efe6",
    "tab.inactiveForeground": "#e7e2d8",
    "scrollbarSlider.background": "#163732",
    "scrollbarSlider.hoverBackground": "#26524b",
    "scrollbarSlider.activeBackground": "#26524b",
    "editorSuggestWidget.background": "#163732",
    "editorSuggestWidget.foreground": "#f3efe6",
    "editorSuggestWidget.border": "#163732",
    "editorSuggestWidget.highlightForeground": "#2ea87e",
    "editorSuggestWidget.selectedBackground": "#112e2a",
    "editorSuggestWidget.selectedForeground": "#f3efe6",
    "editorWidget.background": "#163732",
    "editorWidget.border": "#163732",

    // Lists and Trees
    "list.activeSelectionBackground": "#26524b",
    "list.activeSelectionForeground": "#f3efe6",
    "list.inactiveSelectionBackground": "#163732",
    "list.inactiveSelectionForeground": "#e7e2d8",
    "list.hoverBackground": "#163732",
    "list.hoverForeground": "#f3efe6",
    "list.focusBackground": "#26524b",
    "list.focusForeground": "#f3efe6",
    "list.highlightForeground": "#2ea87e",

    // Inputs
    "input.background": "#163732",
    "input.foreground": "#f3efe6",
    "input.border": "#1b413b",
    "input.placeholderForeground": "#748a92",
    "inputOption.activeBackground": "#2ea87e33",
    "inputOption.activeBorder": "#2ea87e",
    "inputValidation.errorBackground": "#F4384122",
    "inputValidation.errorBorder": "#F43841",
    "inputValidation.warningBackground": "#cc8c3c22",
    "inputValidation.warningBorder": "#cc8c3c",
    "inputValidation.infoBackground": "#7ad0c622",
    "inputValidation.infoBorder": "#7ad0c6",

    // Buttons
    "button.background": "#163732",
    "button.foreground": "#f3efe6",
    "button.border": "#1b413b",
    "button.hoverBackground": "#26524b",
    "button.secondaryBackground": "#26524b",
    "button.secondaryForeground": "#f3efe6",
    "button.secondaryHoverBackground": "#163732",

    // Dropdown and Menus
    "dropdown.foreground": "#f3efe6",
    "menu.foreground": "#f3efe6",
    "menu.border": "#1b413b",
    "menu.selectionForeground": "#f3efe6",

    // Notifications
    "notificationCenterHeader.background": "#112e2a",
    "notifications.background": "#163732",
    "notifications.foreground": "#f3efe6",
    "notifications.border": "#1b413b",

    // Misc Surfaces
    "peekView.border": "#1b413b",
    "peekViewEditor.background": "#112e2a",
    "peekViewResult.background": "#163732",
    "peekViewTitle.background": "#112e2a",
    "peekViewResult.selectionBackground": "#26524b",
    "peekViewEditor.matchHighlightBackground": "#26524b",
    "progressBar.background": "#2ea87e",
    "badge.foreground": "#f3efe6",
    "breadcrumb.foreground": "#e7e2d8",
    "breadcrumb.activeSelectionForeground": "#f3efe6",
    "breadcrumb.focusForeground": "#f3efe6",
    "checkbox.background": "#163732",
    "checkbox.border": "#1b413b",
    "checkbox.foreground": "#f3efe6",
    "settings.headerForeground": "#f3efe6",
    "settings.modifiedItemIndicator": "#2ea87e",
    "statusBarItem.remoteBackground": "#163732",
    "statusBarItem.remoteForeground": "#f3efe6",

    // Panel and Dropdown
    "panel.background": "#163732",
    "panel.border": "#1b413b",
    "panelTitle.activeBorder": "#26524b",
    "panelTitle.activeForeground": "#f3efe6",
    "panelTitle.inactiveForeground": "#e7e2d8",
    "dropdown.background": "#163732",
    "dropdown.border": "#163732",
    "menu.selectionBackground": "#112e2a",

    // Debugging
    "debugToolBar.background": "#163732",
    "debugToolBar.border": "#163732",
    "terminal.background": "#112e2a",
    "terminal.border": "#1b413b",
    "contrastBorder": "#00000000",
    "contrastActiveBorder": "#00000000",

    // Badge
    "badge.background": "#2ea87e",
    "badge.foreground": "#f3efe6",

    // Welcome Page
    "welcomePage.background": "#163732"
  },
    "tokenColors": [
        {
            "scope": "comment, punctuation.definition.comment",
            "settings": {
                "foreground": "#21d813"
            }
        },
        {
            "scope": "string",
            "settings": {
                "foreground": "#2ea87e"
            }
        },
        {
            "scope": "constant, constant.numeric, constant.character, constant.language, constant.other.symbol, constant.character.escape, support.constant",
            "settings": {
                "foreground": "#7ad0c6"
            }
        },
        {
            "scope": "keyword, keyword.control, keyword.other.special-method, token.package.keyword",
            "settings": {
                "foreground": "#ffffff",
                "fontStyle": "bold"
            }
        },
        {
            "scope": "keyword.control.directive.include, meta.preprocessor.include.cpp, punctuation.definition.directive, meta.preprocessor.include.cpp",
            "settings": {
                "foreground": "#8cde94",
            }
        },
        {
            "scope": "punctuation",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "keyword.operator",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "storage.modifier",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "storage, token.storage",
            "settings": {
                "foreground": "#ffffff"
            }
        },
        {
            "scope": "storage.type, storage.type.primitive, storage.type.built-in, storage.type.builtin",
            "settings": {
                "foreground": "#8CDE94"
            }
        },
        {
            "scope": "variable, variable.language, variable.parameter, variable.parameter.function, variable.function, support.variable, entity.name.variable, meta.definition.variable.name, meta.property.object, text.variable, variable.interpolation",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "meta.block",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "entity.name.function, entity.name.method, support.function, meta.function-call, meta.require",
            "settings": {
                "foreground": "#c1d1e3"
            }
        },
        {
            "scope": "entity.name.function.preprocessor, entity.name.function.preprocessor.cpp, meta.preprocessor",
            "settings": {
                "foreground": "#7ad0c6"
            }
        },
        {
            "scope": "entity.name.function.operator.member.cpp, entity.name.function.operator.cpp, punctuation.separator.pointer-access.cpp",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "support.class, support.type, entity.name.type, entity.name.class, entity.other.inherited-class, variable.other.class, meta.type, meta.type.annotation, meta.return-type, keyword.other.type, meta.other.type, support.module, meta.import, keyword.other.import, storage.type.primitive, storage.type.built-in, storage.type.builtin",
            "settings": {
                "foreground": "#8cde94"
            }
        },

        {
            "scope": "entity.name.namespace",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "punctuation.separator",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "punctuation.section",
            "settings": {
                "foreground": "#d8c5a7"
            }
        },
        {
            "scope": "invalid",
            "settings": {
                "foreground": "#F43841"
            }
        }
    ]
}
